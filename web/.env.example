# Public, non-secret. The URL of the deployed FastAPI backend (Render web service).
# Leave EMPTY to run the frontend in Judge Mode only (scripted data, no backend).
# On Render, set this on the static site to your backend's URL, e.g.:
#   VITE_API_BASE_URL=https://ndt-api.onrender.com
VITE_API_BASE_URL=
