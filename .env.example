# Copy to .env and fill in. The Claude API key is the only hard requirement.
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (defaults are sensible; override only if you know why).
NDT_MODEL=claude-opus-4-8
NDT_FAST_MODEL=claude-haiku-4-5
NDT_EFFORT=high

# Storage
NDT_DB_URL=sqlite:///data/app.db
NDT_CHROMA_DIR=data/chroma

# Voice (optional). Leave VOICE_ENABLED=false to run in text mode.
NDT_VOICE_ENABLED=false
NDT_TTS_BACKEND=offline        # offline | none
NDT_STT_BACKEND=whisper        # whisper | none
NDT_WHISPER_MODEL=base.en
